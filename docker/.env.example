# Environment variables — copy to .env and fill in your values

# === Required: Xiaomi Account ===
MI_USER=your_xiaomi_id
MI_PASS=your_xiaomi_password
MI_DID=XiaoAi-Speaker-Pro

# === Required: OpenClaw Agent ===
OPENCLAW_URL=http://localhost:3000
# OPENCLAW_TOKEN=your_openclaw_token
# OPENCLAW_MODEL=openclaw

# === Optional: Speaker Settings ===
MI_DEBUG=false
MI_TIMEOUT=5000
# MI_HEARTBEAT=1000

# === Optional: AI Wake Words (comma-separated) ===
# CALL_AI_KEYWORDS=请,你

# === Optional: Streaming TTS ===
# Set to false if your XiaoAi speaker doesn't support streaming TTS.
# STREAM_RESPONSE=true

# === Optional: Embedded MCP Server Port ===
# The voice gateway includes an embedded MCP server for device control.
# OpenClaw connects to http://<host>:<MCP_PORT>/mcp
# MCP_PORT=3001

# === Optional: MIoT TTS Command ===
# Required for speakers where MiNA ubus text_to_speech doesn't work (e.g. L05C).
# See https://github.com/idootop/mi-gpt/blob/main/docs/compatibility.md
# TTS_SIID=5
# TTS_AIID=3

# === Optional: Thinking Placeholder ===
# Text spoken immediately after intercepting a query, while OpenClaw processes it.
# THINKING_TEXT=请稍候

# === Optional: Extra System Prompt ===
# Appended to the built-in TTS prompt for every request to OpenClaw.
# Use for user-specific context, e.g. timezone or preferences.
# USER_PROMPT=用户所在时区是北京时间（UTC+8）。

# === Optional: Pass Token (alternative to MI_PASS) ===
# MI_PASS_TOKEN=your_pass_token
